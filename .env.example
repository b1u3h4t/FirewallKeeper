# 复制为 .env，用于 docker compose 注入密钥（可选，也可写在 config.yaml）

# 腾讯云
TENCENT_SECRET_ID=AKIDxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxxxxxxxxxx
TENCENT_REGION=ap-guangzhou
LIGHTHOUSE_INSTANCE_ID=lhins-xxxxxxxx

# 阿里云国际版 SWAS
ALIBABA_CLOUD_ACCESS_KEY_ID=LTAIxxxxxxxx
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxx
ALIBABA_CLOUD_REGION=us-east-1
ALIBABA_CLOUD_SWAS_INSTANCE_ID=your-instance-id

# Scaleway Instance 安全组
SCW_SECRET_KEY=scw-secret-key
SCW_DEFAULT_ZONE=fr-par-1
SCW_SECURITY_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AWS Lightsail
AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_LIGHTSAIL_INSTANCE_NAME=MyLightsailInstance

# 火山引擎安全组
VOLCENGINE_ACCESS_KEY_ID=AKLTxxxxxxxx
VOLCENGINE_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
VOLCENGINE_REGION=cn-beijing
VOLCENGINE_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxx

# Hetzner Cloud 防火墙
HCLOUD_TOKEN=your-hcloud-token
HCLOUD_FIREWALL_ID=12345

# Hetzner Robot 独立服务器防火墙
HETZNER_ROBOT_USER=your-robot-user
HETZNER_ROBOT_PASSWORD=your-robot-password
HETZNER_ROBOT_SERVER_NUMBER=321

TZ=Asia/Shanghai
